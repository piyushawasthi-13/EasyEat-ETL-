# ─────────────────────────────────────────────────────────────────────────────
# EasyEat ETL Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (source database)
POSTGRES_DSN=postgresql://easyeat:easyeat_secret@localhost:5432/easyeat

# MongoDB connection URI (target database)
MONGO_URI=mongodb://easyeat:easyeat_secret@localhost:27017

# ── Optional (shown with defaults) ───────────────────────────────────────────

# MongoDB database name
# MONGO_DB=easyeat

# MongoDB collection for aggregated daily metrics
# MONGO_METRICS_COLLECTION=daily_metrics

# MongoDB collection for watermark / pipeline state
# MONGO_STATE_COLLECTION=pipeline_state

# Number of rows to extract per batch (min: 100, max: 50000)
# BATCH_SIZE=5000

# PostgreSQL server-side cursor fetch chunk size (min: 100, max: 50000)
# CURSOR_ITERSIZE=5000

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# Unique identifier for this pipeline instance (used as the watermark key in MongoDB)
# PIPELINE_ID=daily_metrics_etl
